	</insert>-->

	<insert id="insertPaymentRegistration" parameterType="map">
		INSERT INTO payment_resistration (
			pay_no,
			company_no
			)
		VALUES (
			#{payNo},
			#{companyNo}
		)
	
	</insert>
</mapper>